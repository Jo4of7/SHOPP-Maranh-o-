<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Shopping Maranhão</title>
  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #f5f5f5;
    }
    header {
      background: #0d6efd;
      color: white;
      padding: 15px;
      text-align: center;
      font-size: 22px;
    }
    .produtos {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }
    .produto {
      background: white;
      margin: 10px;
      padding: 10px;
      width: 150px;
      border-radius: 10px;
      text-align: center;
    }
    button {
      background: green;
      color: white;
      border: none;
      padding: 8px;
      border-radius: 5px;
    }
  </style>
</head>

<body>

<header>Shopping Maranhão</header>

<div class="produtos">
  <div class="produto">
    <h3>Camisa</h3>
    <p>R$ 50</p>
    <button>Comprar</button>
  </div>

  <div class="produto">
    <h3>Tenis</h3>
    <p>R$ 120</p>
    <button>Comprar</button>
  </div>

  <div class="produto">
    <h3>Relógio</h3>
    <p>R$ 80</p>
    <button>Comprar</button>
  </div>
</div>

</body>
</html>
